{
  "name": "inwitclipps-backend",
  "version": "1.0.0",
  "description": "InwitClipps — AI Video Clipping Platform Backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "workers": "node src/workers/index.js",
    "workers:dev": "node --watch src/workers/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.2",
    "bullmq": "^5.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "openai": "^4.56.0",
    "pg": "^8.12.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "drizzle-kit": "^0.24.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
