PORT=3001
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Upstash Redis (BullMQ)
UPSTASH_REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# TrendSync — InwitClipps' competitive differentiator
# Fetches real-time trending topics from TikTok, YouTube, and X
APIFY_API_KEY=apify_api_...
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAMLheAAAAAAA0%2BuSeid...
YOUTUBE_API_KEY=AIzaSy...

# Supabase Storage bucket names
STORAGE_RAW_BUCKET=raw-videos
STORAGE_CLIPS_BUCKET=rendered-clips

# Temp directory for video processing (workers use this)
TMP_DIR=/tmp/inwitclipps
